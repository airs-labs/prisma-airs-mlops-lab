# AIRS Model Security Authentication
# Required for scanning models via Prisma AIRS SDK
#
# This project uses profile-based credential management:
#   - .env.superuser         (full access including PyPI registry)
#   - .env.model-security    (model security API only)
#
# Switch profiles using AIRS_PROFILE environment variable:
#   export AIRS_PROFILE=superuser         # default
#   export AIRS_PROFILE=model-security    # limited permissions
#
# Create your credential files by copying this template:
#   cp .env.example .env.superuser
#   cp .env.example .env.model-security
#   # Then fill in your actual credentials in each file

# Service account client ID from Strata Cloud Manager
MODEL_SECURITY_CLIENT_ID=your-service-account@your-tsg.iam.panserviceaccount.com

# Service account client secret
MODEL_SECURITY_CLIENT_SECRET=your-client-secret-uuid

# Tenant Service Group ID (numeric)
TSG_ID=your-tsg-id

# Optional: API endpoint (defaults to production)
# MODEL_SECURITY_API_ENDPOINT=https://api.sase.paloaltonetworks.com/aims
