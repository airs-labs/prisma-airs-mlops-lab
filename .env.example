GCP_REGION=us-central1          # GCP region for deployments
TSG_ID=                         # From: SCM > Common Services > Tenant Management

# ===== Leaderboard =====
LEADERBOARD_URL=https://leaderboard.airs-labs.net
LEADERBOARD_API_KEY=            # API key for leaderboard submissions

# ===== Lab-Specific: Model Security (MLOps Lab) =====
AIRS_MS_CLIENT_ID=              # Model Security SA Client ID (from SCM service account)
AIRS_MS_CLIENT_SECRET=          # Model Security SA Client Secret
